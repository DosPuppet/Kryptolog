ALLOWED_ORIGINS=http://localhost:5173

# Deployment mode. Set to "production" for real deployments: the backend then
# REFUSES TO START unless a persistent ML-DSA signing key is configured (below).
# Default "development" allows an ephemeral key for local runs.
KRYPTOLOG_ENV=development

# Comma-separated IPs of trusted reverse proxies (e.g. your nginx host). Rate
# limiting only honors X-Real-IP / X-Forwarded-For when the direct peer is one
# of these — otherwise clients could spoof headers to dodge limits. Default:
# 127.0.0.1 (nginx on the same host). Set to your proxy IP(s) if it differs.
TRUSTED_PROXY_IPS=127.0.0.1

# Rate-limit storage (audit F-3). Unset ⇒ in-memory: fine for a SINGLE process,
# but limits are per-process and reset on restart. Point this at Redis for
# durable, shared limits (login throttles survive restarts) — and a prerequisite
# for ever running more than one process. RATELIMIT_STORAGE_URI overrides; a plain
# REDIS_URL is reused if set. NOTE: the backend is single-process today (the
# WebSocket manager + presence are in-memory); do not run multiple workers until
# those are shared too.
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URI=redis://localhost:6379/1

# JWT signing secret (HS256). Generate once with
#   python generate_server_keys.py
# and paste the line here. Forges JWTs if leaked — treat it like any production
# secret. REQUIRED when KRYPTOLOG_ENV=production; if unset in development the
# backend uses an ephemeral secret (all JWTs reset on restart).
KRYPTOLOG_JWT_SECRET=

# Access filter (audit §5). When "true", registering a brand-new identity at
# first login requires a valid invite code; existing users are unaffected. Seed
# codes with `python generate_invites.py`. Default (unset/false): open signup.
KRYPTOLOG_REQUIRE_INVITE=false

VAPID_PUBLIC_KEY=<your-vapid-public-key>
VAPID_PRIVATE_KEY=<your-vapid-private-key>
VAPID_SUBJECT=mailto:admin@kryptolog.io
