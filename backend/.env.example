ALLOWED_ORIGINS=http://localhost:5173

# Server ML-DSA-44 signing keypair (FIPS 204). Generate once with
#   python generate_server_keys.py
# and paste both lines here. The secret key forges JWTs if leaked — treat it
# like any production secret. If unset, the backend uses an ephemeral key and
# all JWTs become invalid on restart.
SAFELOG_ML_DSA_PUBLIC_KEY=
SAFELOG_ML_DSA_SECRET_KEY=

VAPID_PUBLIC_KEY=<your-vapid-public-key>
VAPID_PRIVATE_KEY=<your-vapid-private-key>
VAPID_SUBJECT=mailto:admin@safelog.io
GOOGLE_CLIENT_ID=
