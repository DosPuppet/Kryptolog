VITE_API_BASE_URL=http://localhost:8000
# Comma-separated list of allowed hosts for Vite dev server (e.g. kryptolog.hashpar.com)
ALLOWED_HOSTS=

# Web Push: the PUBLIC half of the server's VAPID keypair. Must match the
# backend's VAPID_PRIVATE_KEY. Generate a pair once (see README "Push
# notifications"), then set the public key here and the private key on the
# backend. Leave empty to disable push.
VITE_VAPID_PUBLIC_KEY=
